# Per-workspace overrides consumed by `solvo run`. Edit to taste.
SOLVO_INTERVAL=600
SOLVO_MEMORY=2g
SOLVO_CPUS=2
# Wall-clock timeout per `claude -p` subprocess. SIGTERM at this mark,
# SIGKILL 10s later. Tune higher for workspaces with long deploy/build
# steps.
SOLVO_TICK_TIMEOUT_S=3600
SOLVO_MODEL=opus
