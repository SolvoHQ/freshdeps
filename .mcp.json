{
  "_comment": "Copied to <workspace>/.mcp.json by `solvo init`. Claude Code auto-discovers MCP servers from this file when running in the workspace dir.",
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser=chromium",
        "--user-data-dir=/home/solvo/.cache/chrome-profile"
      ],
      "env": {}
    },
    "computer-use": {
      "command": "python",
      "args": ["-m", "solvo.mcp.computer_use"],
      "env": {}
    }
  }
}
